# ============================================================================
# NOVATAXI BACKEND - ENVIRONMENT VARIABLES CONFIGURATION
# ============================================================================
# Copy this file to .env and update values for your environment
# DO NOT commit .env to version control - it contains secrets!
# ============================================================================

# ============================================================================
# DJANGO SETTINGS
# ============================================================================

# Set to False in production
DEBUG=True

# Generate a secret key:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-change-in-production

# Comma-separated list of allowed hosts
# Format: localhost,127.0.0.1,example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
# Format: postgres://username:password@host:port/database_name
# For Docker: postgres://novataxi:novataxi@db:5432/novataxi
# For Local: postgres://novataxi:novataxi@localhost:5432/novataxi

DATABASE_URL=postgres://novataxi:novataxi@localhost:5432/novataxi

# PostgreSQL connection pool settings (optional)
# DB_CONN_MAX_AGE=600
# DB_POOL_SIZE=10

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins for CORS
# Format: http://localhost:3000,http://localhost:3001,https://example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# AUTHENTICATION & JWT SETTINGS
# ============================================================================

# JWT Token Lifetimes
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# Password Policy Settings
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_REQUIRE_UPPERCASE=True
AUTH_REQUIRE_LOWERCASE=True
AUTH_REQUIRE_DIGITS=True
AUTH_REQUIRE_SPECIAL_CHARS=True

# Account Lockout Settings (for brute force protection)
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=15

# Email Verification Settings
EMAIL_VERIFICATION_TOKEN_EXPIRY_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=24

# Authentication Endpoints
AUTH_REGISTER_ENABLED=True
AUTH_LOGIN_ENABLED=True
AUTH_EMAIL_VERIFICATION_ENABLED=True
AUTH_PASSWORD_RESET_ENABLED=True

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# Email backend: django.core.mail.backends.smtp.EmailBackend
# For development: django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP Settings (if using SMTP backend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@novataxi.com

# Email Verification Settings
SEND_VERIFICATION_EMAIL=False
SEND_WELCOME_EMAIL=False
SEND_PASSWORD_RESET_EMAIL=False

# Email Frontend URLs (for links in emails)
FRONTEND_VERIFY_EMAIL_URL=http://localhost:3000/verify-email
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
FRONTEND_SUPPORT_EMAIL=support@novataxi.com

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Django logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
DJANGO_LOG_LEVEL=INFO

# NovaTaxi app logging level
NOVATAXI_LOG_LEVEL=DEBUG

# Log file locations (optional)
# LOG_FILE=/var/log/novataxi/app.log
# ERROR_LOG_FILE=/var/log/novataxi/error.log

# ============================================================================
# SECURITY SETTINGS (PRODUCTION)
# ============================================================================
# HTTPS and SSL
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Security Headers
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_SECURITY_POLICY=True
X_FRAME_OPTIONS=DENY

# HSTS (HTTP Strict-Transport-Security)
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ============================================================================
# AWS CONFIGURATION (for media storage - optional)
# ============================================================================
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_STORAGE_BUCKET_NAME=novataxi-media
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=cdn.novataxi.com

# ============================================================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================================================
# Stripe
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# PayPal
# PAYPAL_CLIENT_ID=...
# PAYPAL_SECRET=...

# ============================================================================
# REDIS CONFIGURATION (for caching/sessions - optional)
# ============================================================================
# REDIS_URL=redis://localhost:6379/0
# CACHE_TIMEOUT=300

# ============================================================================
# CELERY CONFIGURATION (for async tasks - optional)
# ============================================================================
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# CELERY CONFIGURATION (for async tasks - optional)
# ============================================================================
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# CELERY_ACCEPT_CONTENT=json
# CELERY_TASK_SERIALIZER=json

# ============================================================================
# MONITORING & LOGGING (optional)
# ============================================================================
# Sentry error tracking
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================================================
# OTHER SETTINGS
# ============================================================================
# Timezone
TIME_ZONE=UTC

# Language code
LANGUAGE_CODE=en-us

# ============================================================================
# SECURITY SETTINGS (Production)
# ============================================================================
# HTTPS/SSL Settings
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True

# ============================================================================
# RATE LIMITING (optional)
# ============================================================================
# RATELIMIT_ENABLE=True
# RATELIMIT_USE_CACHE=default
